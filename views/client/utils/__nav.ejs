<nav>
    <div class="logo">
        <a href="/"><i class="fas fa-asterisk"></i> Capnin</a> 
    </div>
    <div class="links">
        <a href="/">Home</a>
        <a href="/shop">Shop All</a>
        <a href="/#contact">Contact Us</a>
    </div>
    <div class="nav-actions">
        <a href="/shop" class="btn-primary">Shop Now</a>
    </div>
    <div class="linksMoblie">
        <i class="fas fa-bars"></i>
    </div>
</nav>
<script>
    const bars = document.querySelector(".linksMoblie");
    bars.addEventListener("click",()=>{
        document.querySelector("nav").querySelector(".links").classList.toggle('active-links');
    });
</script>
<style>


    nav {
        height: 70px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 5%;
        background: #f5f6f8; /* Soft off-white like BloomFi */
        position: sticky;
        top: 0;
        z-index: 1000;
        font-family: "Outfit", sans-serif;
    }

    nav .logo {
        flex: 1;
        display: flex;
        align-items: center;
    }

    nav .logo a {
        font-size: 20px;
        color: #1a1a24;
        text-decoration: none;
        font-weight: 500;
        letter-spacing: -0.01em;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    nav .logo a i {
        font-size: 22px;
        color: #1e1e2d;
    }

    nav .links {
        flex: 2;
        display: flex;
        justify-content: center;
        align-items: center;
    }
  
    nav .links a {
        text-decoration: none;
        color: #4a4a5a;
        padding: 0 20px;   
        font-weight: 500;
        font-size: 15px;
        transition: color 0.2s ease;
    }
    
    nav .links a:hover {
        color: #1a1a24;
    }
    
    nav .nav-actions {
        flex: 1;
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }
    
    nav .btn-primary {
        background-color: #272635; /* Dark pill background */
        color: #ffffff;
        text-decoration: none;
        padding: 10px 24px;
        border-radius: 50px; /* Pill shape */
        font-weight: 500;
        font-size: 14px;
        transition: opacity 0.2s ease;
    }

    nav .btn-primary:hover {
        opacity: 0.9;
    }

    nav .linksMoblie {
        color: #1a1a24;
        font-size: 20px;
        cursor: pointer;
        display: none;
    }

    @media (max-width: 760px) {
        nav .links {
            display: none;
        }
        nav .links.active-links {
            position: absolute;
            top: 70px;
            left: 0;
            width: 100%;
            background: #ffffff;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            flex-direction: column;
            padding: 20px 0;
            gap: 15px;
            box-shadow: 0 5px 10px rgba(0,0,0,0.05);
        }
        nav .links.active-links a {
            padding: 10px 0;
        }
        nav .nav-actions {
            display: none;
        }
        nav .linksMoblie {
            display: block;
        }
        nav .logo {
            flex-grow: 1;
        }
    }
</style>